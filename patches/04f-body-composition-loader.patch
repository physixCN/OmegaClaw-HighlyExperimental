+        self.assertIn("skill_catalog_body.metta", body)
+        self.assertIn("skill_catalog_channels.metta", body)
+        self.assertIn("modules/publishing/entry.metta", body)
+        self.assertIn("modules/gameboy/entry.metta", body)
+        self.assertIn("modules/omega_vm/entry.metta", body)
+        self.assertNotIn("skill_catalog_web.metta", body)
