diff --git a/lib_omegaclaw_assume.metta b/lib_omegaclaw_assume.metta
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/lib_omegaclaw_assume.metta
@@ -0,0 +1,22 @@
+; Optional Assume / FabricPC predictive organ.
+;
+; Core OmegaClaw can run without this file. A situated instance imports it when
+; it wants the warm predictive membrane and canonical &assume space available.
+
+!(import! &self (car-atom (collapse (library OmegaClaw-Core ./src/assume.py))))
+!(import! &self (car-atom (collapse (library OmegaClaw-Core ./src/assume_client.py))))
+!(import! &self (car-atom (collapse (library OmegaClaw-Core ./src/skill_catalog_assume.metta))))
+!(import! &self (car-atom (collapse (library OmegaClaw-Core ./src/skill_affordance_assume.metta))))
+!(import! &self (car-atom (collapse (library OmegaClaw-Core ./src/skills_assume.metta))))
+!(bind! &assume (new-space))
+!(bind! &assume_work (new-space))
+!(register-space "assume" &assume prediction)
+!(register-space-alias assume "assume")
+!(register-space-persistence "assume" ./repos/OmegaClaw-Core/memory/assume.metta runtime-state)
+
+(RuntimeOrgan "assume" (initAssumeOrgan))
+(TrustedRuntimeOrgan "assume")
+
+(= (initAssumeOrgan)
+   (progn (load-runtime-space "assume")
+          (py-call (assume_client.start))))
