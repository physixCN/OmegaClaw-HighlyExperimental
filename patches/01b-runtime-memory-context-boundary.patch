+
+(= (assimilate-world $spec)
+   (let* (($atom (py-call (helper.assimilation_world_atom $spec)))
+          ($parsed (sread $atom)))
+        (if (== (car-atom $parsed) AssimilationWorldError)
+            (py-str (ASSIMILATE-WORLD-SHAPE-WARNING: $atom raw-command-preserved-in-history no-world-atom-written))
+            (progn (add-atom &world $parsed)
+                   (trace-atom "write" "world" $parsed "assimilate-world")
+                   (py-str (ASSIMILATED-WORLD: $atom))))))
+
+(= (assimilate-belief $spec)
+   (let* (($atom (py-call (helper.assimilation_belief_atom $spec)))
+          ($parsed (sread $atom)))
+        (if (== (car-atom $parsed) AssimilationBeliefError)
+            (py-str (ASSIMILATE-BELIEF-SHAPE-WARNING: $atom raw-command-preserved-in-history no-belief-atom-written))
