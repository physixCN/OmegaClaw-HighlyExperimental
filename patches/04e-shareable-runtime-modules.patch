+OMEGACLAW_CODEX_SANDBOX_READONLY = { required = false, default = "read-only" }
+OMEGACLAW_CODEX_SANDBOX_EDIT = { required = false, default = "workspace-write" }
+OMEGACLAW_CODEX_DANGEROUS_BYPASS = { required = false, default = "0" }
+OMEGACLAW_CODEX_MAX_ACTIVE_JOBS = { required = false, default = "1" }
+
+[trace]
+writes = [
+  "CodexCodeCall",
+  "CodexCodeResult",
+  "CodexJobStarted",
+  "CodexJobComplete",
+  "CodexJobError",
+]
