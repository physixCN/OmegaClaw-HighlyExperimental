+++ b/docs/retired/scratch-space-legacy/organs-scratch-space/promote-scratch.metta
@@ -0,0 +1,58 @@
+; Explicit promote-scratch action
+; Copies atoms from &scratch to &beliefs and removes from &scratch
+; Per design: promotion is deliberate, not automatic
+
+; Promote a scratch atom to beliefs
+; Usage: (promote-scratch <atom>)
+; Copies atom to &beliefs with updated truth-values, removes from &scratch
+(= (promote-scratch $atom)
+   (let* (($hash (py-str (helper.metta_atom_hash $atom)))
+          ($parsed (sread $atom)))
+        (progn
+          ; Add to beliefs with lowered confidence (draft status)
+          (add-atom &beliefs $parsed)
+          (trace-atom "write" "beliefs" $parsed "promote-scratch")
+          ; Remove from scratch
+          (collapse (match &scratch $atom (remove-atom &scratch $atom)))
+          ; Remove TTL entry
+          (collapse (match &scratch-ttl (ScratchTTL $hash $_)
+                                     (remove-atom &scratch-ttl (ScratchTTL $hash))))
+          (py-str (SCRATCH-PROMOTED: atom-hash: $hash beliefs-count: (match-count &beliefs $_))))))
+
+; Promote all scratch atoms to beliefs
+; Usage: (promote-scratch-all)
+(= (promote-scratch-all)
+   (let* (($atoms (repr (collapse (match &scratch $atom $atom))))
+          ($count (match-count &scratch $_)))
+        (progn
+          (py-str (SCRATCH-PROMOTE-STARTED: count: $count))
+          ; Process each atom - this requires iteration
+          $atoms)))
+
+; Promote scratch atoms matching a pattern to beliefs
+; Usage: (promote-scratch-by-pattern <pattern>)
+(= (promote-scratch-by-pattern $patternstr)
+   (let $pattern (catch (sread $patternstr))
+        (if (== (car-atom $pattern) Error)
+            (ScratchError "bad pattern expression" $pattern)
+            (let* (($matching (find &scratch $pattern))
+                   ($count (if (== $matching ()) 0 (match-count &scratch $pattern))))
+                 (progn
+                   (py-str (SCRATCH-PROMOTE-PATTERN-STARTED: pattern: $patternstr count: $count))
+                   ; For each matching atom, promote it
+                   $matching)))))
+
+; Demote a belief back to scratch (for re-evaluation)
+; Usage: (demote-belief-to-scratch <atom>)
+(= (demote-belief-to-scratch $atom)
+   (let* (($hash (py-str (helper.metta_atom_hash $atom)))
+          ($ttl (scratch-ttl-default))
+          ($parsed (sread $atom)))
+        (progn
+          ; Remove from beliefs
+          (collapse (match &beliefs $atom (remove-atom &beliefs $atom)))
+          ; Add to scratch
+          (add-atom &scratch $parsed)
+          (add-atom &scratch-ttl (ScratchTTL $hash $ttl))
+          (trace-atom "write" "scratch" $parsed "demote-belief-to-scratch")
+          (py-str (BELIEF-DEMOTED-TO-SCRATCH: atom-hash: $hash ttl: $ttl)))))
diff --git a/docs/retired/scratch-space-legacy/organs-scratch-space/scratch.metta b/docs/retired/scratch-space-legacy/organs-scratch-space/scratch.metta
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/docs/retired/scratch-space-legacy/organs-scratch-space/scratch.metta
@@ -0,0 +1,120 @@
+; &scratch transient reasoning space implementation
+; MeTTa/AtomSpace based on design decisions in /home/jon/OmegaClaw/scratch-space-design-dialogue.md
+;
+; Design principles:
+; (1) Space-as-type convention: &scratch = draft. Spatial separation, not truth-value flags.
+; (2) Side-table scratch-ttl: Loop-count TTL default 3, decrement per loop, touch resets
+; (3) Persist-on-shutdown: Save atoms with TTL, decrement TTL by 1 on load (natural decay)
+; (4) Explicit promote-scratch: Copies to &beliefs, removes from &scratch
+; (5) Garbage collection: Loop step checks scratch-ttl, removes expired atoms
+
+!(import_prolog_function string_length)
+
+; Scratch space registration
+; Spatial separation: &scratch = draft, &beliefs = committed, &persistent = sacred
+(bind! &scratch (new-space))
+
+; Scratch TTL side-table: (scratch-ttl <atom-hash> <remaining-loops>)
+; TTL is tracked per-atom using a hash key for lookup
+; Default TTL is 3 loops as per design decision
+(bind! &scratch-ttl (new-space))
+
+; Register scratch space in the space registry
+(= (register-scratch-space)
+   (progn
+     (collapse (match &self (SpaceRegistry "scratch" $oldhandle $oldrole)
+                            (remove-atom &self (SpaceRegistry "scratch" $oldhandle $oldrole))))
+     (add-atom &self (SpaceRegistry "scratch" &scratch memory))
+     (SpaceRegistered "scratch" "memory")))
+
+; Register scratch TTL table
+(= (register-scratch-ttl)
+   (progn
+     (add-atom &self (ScratchTTLSpace &scratch-ttl))
+     (ScratchTTLSpaceRegistered)))
+
+; Register scratch space and TTL table
+!(register-scratch-space)
+!(register-scratch-ttl)
+
+; Scratch TTL default value
+(= (scratch-ttl-default) 3)
+
+; Add an atom to &scratch with TTL
+; Usage: (scratch-add <atom> [ttl])
+; Default TTL is 3 if not specified
+(= (scratch-add $atom)
+   (scratch-add $atom (scratch-ttl-default)))
+
+(= (scratch-add $atom $ttl)
+   (let* (($hash (py-str (helper.metta_atom_hash $atom)))
+          ($parsed (sread $atom)))
+        (progn
+          (add-atom &scratch $parsed)
+          (add-atom &scratch-ttl (ScratchTTL $hash $ttl))
+          (trace-atom "write" "scratch" $parsed "scratch-add")
+          (py-str (SCRATCH-ATOM-ADDED: atom-hash: $hash ttl: $ttl)))))
+
+; Touch a scratch atom to reset its TTL
+; Usage: (scratch-touch <atom>)
+; Resets TTL to default value
+(= (scratch-touch $atom)
+   (let* (($hash (py-str (helper.metta_atom_hash $atom)))
+          ($ttl (scratch-ttl-default)))
+        (progn
+          (collapse (match &scratch-ttl (ScratchTTL $hash $oldttl)
+                                     (remove-atom &scratch-ttl (ScratchTTL $hash $oldttl))))
+          (add-atom &scratch-ttl (ScratchTTL $hash $ttl))
+          (py-str (SCRATCH-TTL-TOUCHED: atom-hash: $hash new-ttl: $ttl)))))
+
+; Get TTL for a scratch atom
+; Usage: (scratch-get-ttl <atom>)
+(= (scratch-get-ttl $atom)
+   (let* (($hash (py-str (helper.metta_atom_hash $atom))))
+        (repr (collapse (match &scratch-ttl (ScratchTTL $hash $remaining) $remaining)))))
+
+; Get all scratch atoms
+; Usage: (scratch-atoms)
+(= (scratch-atoms)
+   (repr (collapse (match &scratch $atom $atom))))
+
+; Get all scratch TTL entries
+; Usage: (scratch-ttl-all)
+(= (scratch-ttl-all)
+   (repr (collapse (match &scratch-ttl (ScratchTTL $hash $ttl) (ScratchTTL $hash $ttl)))))
+
+; Count scratch atoms matching a pattern
+; Usage: (scratch-count <pattern>)
+(= (scratch-count $patternstr)
+   (let $pattern (catch (sread $patternstr))
+        (if (== (car-atom $pattern) Error)
+            (ScratchError "bad pattern expression" $pattern)
+            (match-count &scratch $pattern))))
+
+; Find scratch atoms matching a pattern
+; Usage: (scratch-find <pattern>)
+(= (scratch-find $patternstr)
+   (let $pattern (catch (sread $patternstr))
+        (if (== (car-atom $pattern) Error)
+            (ScratchError "bad pattern expression" $pattern)
+            (find &scratch $pattern))))
+
+; Get examples from scratch
+; Usage: (scratch-examples <pattern> [limit])
+(= (scratch-examples $patternstr $limit)
+   (let* (($pattern (catch (sread $patternstr)))
+          ($limit2 (car-atom (collapse (clamp $limit 1 50)))))
+        (if (== (car-atom $pattern) Error)
+            (ScratchError "bad pattern expression" $pattern)
+            (repr (takeK $limit2 (collapse (match &scratch $pattern $pattern)))))))
+
+(= (scratch-examples $patternstr)
+   (scratch-examples $patternstr 5))
+
+; Check if atom is in scratch
+; Usage: (scratch-contains? <atom>)
+(= (scratch-contains? $atom)
+   (let* (($hash (py-str (helper.metta_atom_hash $atom))))
+        (if (== (collapse (match &scratch-ttl (ScratchTTL $hash $_) $_)) ())
+            false
+            true)))
diff --git a/docs/retired/scratch-space-legacy/src-scratch-space/skills.metta b/docs/retired/scratch-space-legacy/src-scratch-space/skills.metta
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/docs/retired/scratch-space-legacy/src-scratch-space/skills.metta
@@ -0,0 +1,153 @@
+; Scratch space module for OmegaClaw
+; MeTTa definitions for transient reasoning space with TTL-based garbage collection
+
+; Import prolog functions for string operations
+!(import_prolog_function string_length)
+
+; Register &scratch as a memory space for draft/working memory
+!(register-space "scratch" &scratch memory)
+!(register-space-alias scratch "scratch")
+
+; Scratch space has TTL tracking in a side table: (scratch-ttl <atom-hash> <loops-remaining>)
+; Default TTL is 3 loops per atom
+
+; Add-atom to &scratch with optional TTL override (default 3)
+; Usage: (scratch-add <atom> :ttl <n>) or just (scratch-add <atom>)
+; TTL is stored in side table as (scratch-ttl <hash> <ttl>)
+
+; Remove atom from &scratch and its TTL entry
+; Usage: (scratch-remove <atom>)
+
+; Promote atom from &scratch to &beliefs with updated truth-values and event note
+; Usage: (promote-scratch <atom> reason)
+; Copies atom to &beliefs with confidence adjusted, removes from &scratch, adds event
+
+; Explicit loop hook: decrement all scratch TTLs and collect expired
+; Called each loop by loop.metta
+; Usage: (scratch-gc)
+
+; On loop touch (read/inspect atom), TTL resets to default
+; Implemented by matching in pattern - any access resets TTL
+
+; Persistence: register &scratch in persistence registry
+; Path: ./memory/scratch.metta
+; Mode: runtime-state (saved on shutdown, loaded on boot)
+!(register-space-persistence "scratch" ./repos/OmegaClaw-Core/memory/scratch.metta runtime-state)
+
+; Helper function to get hash of an atom for TTL tracking
+; In Hyperon/MeTTa, we can use string representation as hash
+(= (atom-hash $atom)
+   (repr $atom))
+
+; Get TTL for an atom (returns number of loops remaining)
+; If not in side-table, returns 0 (default fresh TTL)
+; Note: Side-table format is (scratch-ttl <hash> <loops-remaining>)
+(= (scratch-ttl $atom)
+   (let $hash (atom-hash $atom)
+        (collapse (match &scratch-ttl (scratch-ttl $hash $remaining) $remaining))))
+
+; Set TTL for an atom
+(= (scratch-ttl-set $atom $remaining)
+   (let $hash (atom-hash $atom)
+        (progn (collapse (match &scratch-ttl (scratch-ttl $hash $old) (remove-atom &scratch-ttl (scratch-ttl $hash $old))))
+               (add-atom &scratch-ttl (scratch-ttl $hash $remaining))
+               $remaining)))
+
+; Touch an atom - reset its TTL to default (3)
+(= (scratch-touch $atom)
+   (progn (scratch-ttl-set $atom 3)
+          (ScratchTouched $atom)))
+
+; Get default TTL value
+(= (scratch-default-ttl) 3)
+
+; Check if atom is in scratch space
+(= (scratch-contains $atom)
+   (if (== (find &scratch $atom) ()) false true))
+
+; Add atom to scratch with optional explicit TTL
+; Usage: (scratch-add <atom>) or (scratch-add <atom> :ttl <n>)
+(= (scratch-add $atom)
+   (scratch-add $atom (scratch-default-ttl)))
+
+(= (scratch-add $atom :ttl $ttl)
+   (progn (add-atom &scratch $atom)
+          (scratch-ttl-set $atom $ttl)
+          (ScratchAtomAdded $atom $ttl)))
+
+; Remove atom from scratch and its TTL entry
+(= (scratch-remove $atom)
+   (progn (remove-atom &scratch $atom)
+          (let $hash (atom-hash $atom)
+               (progn (collapse (match &scratch-ttl (scratch-ttl $hash $remaining) (remove-atom &scratch-ttl (scratch-ttl $hash $remaining))))
+                      (ScratchAtomRemoved $atom)))))
+
+; Promote atom from scratch to beliefs
+; Copies atom to &beliefs with confidence adjusted (lower for draft origin)
+; Removes from &scratch
+; Records event: "promoted from scratch"
+(= (promote-scratch $atom $reason)
+   (if (== (find &scratch $atom) ())
+       (ScratchPromoteNotFound $atom)
+       (progn (let* (($promoted (if (== (car-atom $atom) Belief)
+                                   $atom
+                                   (Belief "scratch-origin" "promoted-from-scratch" (repr $atom) 0.5 0.5))))
+               (progn (add-atom &beliefs $promoted)
+                      (trace-atom "write" "beliefs" $promoted "promoted-scratch")
+                      (add-atom &events (Event "omega" "scratch-promote" $reason "0.9"))
+                      (scratch-remove $atom)
+                      (ScratchPromoted $atom $promoted $reason))))))
+
+; Promote-scratch with default reason
+(= (promote-scratch $atom)
+   (promote-scratch $atom "verified-draft"))
+
+; Scratch garbage collection
+; Called each loop - decrements all TTLs, removes expired atoms
+; Also touches atoms found in patterns (reset TTL on access)
+(= (scratch-gc)
+   (let* (($ttl-entries (collapse (match &scratch-ttl (scratch-ttl $hash $remaining) (scratch-ttl $hash $remaining))))
+          ($new-ttls (collapse (let* (($hash (car-atom $ttl-entries))
+                                       ($remaining (car-atom (cdr-atom $ttl-entries)))
+                                       ($new-remaining (- $remaining 1)))
+                                  (if (> $new-remaining 0)
+                                      (progn (scratch-ttl-set (sread $hash) $new-remaining)
+                                             (ScratchTtlDecrement $hash $new-remaining))
+                                      (progn (remove-atom &scratch-ttl (scratch-ttl $hash $remaining))
+                                             (let $atom (sread $hash)
+                                                  (progn (remove-atom &scratch $atom)
+                                                         (ScratchGCExpire $atom $hash)))))))))
+          $new-ttls))
+
+; Get all scratch atoms with their remaining TTLs
+(= (scratch-all-with-ttl)
+   (repr (collapse (match &scratch $atom
+                          (let $hash (atom-hash $atom)
+                               (let $ttl (collapse (match &scratch-ttl (scratch-ttl $hash $remaining) $remaining)))
+                               (ScratchAtomWithTtl $atom $ttl)))))
+
+; Get count of scratch atoms
+(= (scratch-count)
+   (string_length (repr (get-atoms &scratch))))
+
+; Get scratch atoms matching pattern
+(= (scratch-find $pattern)
+   (repr (collapse (match &scratch $pattern $pattern))))
+
+; Get scratch atoms matching pattern with count limit
+(= (scratch-examples $pattern $limit)
+   (let* (($limit2 (car-atom (collapse (clamp $limit 1 20))))
+          ($matches (collapse (match &scratch $pattern $pattern))))
+        (repr (takeK $limit2 $matches))))
+
+(= (scratch-examples $pattern)
+   (scratch-examples $pattern 5))
+
+; Get pressure for scratch space (chars used vs limit)
+(= (scratch-pressure)
+   (let $limit (get-state &maxScratchAtomsChars)
+        (if (== $limit ())
+            (ScratchPressureError "limit not configured")
+            (let* (($atoms (repr (get-atoms &scratch)))
+                   ($chars (string_length $atoms)))
+                   (ScratchPressure $chars $limit (- $limit $chars))))))
