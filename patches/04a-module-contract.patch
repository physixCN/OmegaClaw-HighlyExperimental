+; Core cognitive/runtime affordance cards. These are symbolic declarations,
+; not routing code.
+
+(SkillTopic "send" "core")
+(SkillTopic "wait" "core")
+(SkillTopic "pin" "core")
+(SkillTopic "remember" "core")
+(SkillTopic "query" "core")
+(SkillTopic "episodes-at" "core")
+(SkillTopic "current-swipl-pid" "core")
+(SkillTopic "restart-self" "core")
+(SkillTopic "reboot-self" "core")
+(SkillTopic "shell" "core")
+(SkillTopic "read-file" "core")
+(SkillTopic "write-file" "core")
+(SkillTopic "append-file" "core")
+
+(SkillCardLine "send" "send message - reply through the latest routed control channel")
+(SkillCardLine "wait" "wait reason - deliberately take no external action this cycle")
+(SkillCardLine "pin" "pin state - one-line volatile working memory")
+(SkillCardLine "remember" "remember lesson - store compact future-useful continuity")
+(SkillCardLine "episodes-at" "episodes-at time - inspect history around a flexible timestamp")
+(SkillCardLine "shell" "shell command - run a non-risky shell command inside the VM body")
+(SkillCardLine "write-file" "write-file path content - write a file through the file hand; lowers rich text safely")
+
+(Risk "shell" "vm-command")
+(Risk "write-file" "file-write")
+(Risk "append-file" "file-write")
+(Effect "remember" "ltm-entry")
+(Effect "pin" "working-memory-state")
+(Effect "restart-self" "process-restart")
+
+(SituationFeature "answer-current-human" "open-conversation")
+(PreferredWhen "send" "open-conversation" 0.88 "reply through the current routed channel when an answer is chosen")
+
