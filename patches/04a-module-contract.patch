+!(add-atom &skills (SituationFeature "find-tool-for-task" "unknown-which-skill"))
+!(add-atom &skills (SituationFeature "understand-tool-before-use" "need-skill-shape"))
+!(add-atom &skills (SituationFeature "quick-tool-reminder" "need-compact-skill-reminder"))
+
+; ---------------------------------------------------------------------------
+; Public affordance functions.
+; ---------------------------------------------------------------------------
+
+(= (query-skill-space $topic)
+   (let* (($exact (collapse
+                    (match &skills (SkillTopic $skill $topic)
+                      (SkillCard $topic $skill))))
+          ($symbol (repr $topic))
+          ($by-symbol (collapse
+                        (match &skills (SkillTopic $skill $symbol)
+                          (SkillCard $symbol $skill))))
+          ($self-exact (collapse
+                         (match &self (SkillTopic $skill $topic)
+                           (SkillCard $topic $skill))))
+          ($self-by-symbol (collapse
+                             (match &self (SkillTopic $skill $symbol)
+                               (SkillCard $symbol $skill)))))
+         (list_to_set (append (append $exact $by-symbol)
+                              (append $self-exact $self-by-symbol)))))
+
+(= (choose-skill-for $situation)
+   (let* (($exact (collapse
+                    (match &skills (SituationFeature $situation $feature)
+                      (match &skills (PreferredWhen $skill $feature $confidence $why)
+                        (SkillChoice $situation $skill $confidence $why)))))
+          ($symbol (repr $situation))
+          ($by-symbol (collapse
+                        (match &skills (SituationFeature $symbol $feature)
+                          (match &skills (PreferredWhen $skill $feature $confidence $why)
+                            (SkillChoice $symbol $skill $confidence $why)))))
+          ($self-exact (collapse
+                         (match &self (SituationFeature $situation $feature)
+                           (match &self (PreferredWhen $skill $feature $confidence $why)
+                             (SkillChoice $situation $skill $confidence $why)))))
+          ($self-by-symbol (collapse
+                             (match &self (SituationFeature $symbol $feature)
+                               (match &self (PreferredWhen $skill $feature $confidence $why)
+                                 (SkillChoice $symbol $skill $confidence $why))))))
+         (list_to_set (append (append $exact $by-symbol)
+                              (append $self-exact $self-by-symbol)))))
+
+(= (explain-skill $skill)
+   (let* (($exact (collapse
+                    (match &skills (SkillArg $skill $index $type $name)
+                      (SkillCardArg $skill $index $type $name))))
+          ($symbol (repr $skill))
+          ($by-symbol (collapse
+                        (match &skills (SkillArg $symbol $index $type $name)
+                          (SkillCardArg $symbol $index $type $name))))
+          ($self-exact (collapse
+                         (match &self (SkillArg $skill $index $type $name)
+                           (SkillCardArg $skill $index $type $name))))
+          ($self-by-symbol (collapse
+                             (match &self (SkillArg $symbol $index $type $name)
+                               (SkillCardArg $symbol $index $type $name)))))
+         (list_to_set (append (append $exact $by-symbol)
+                              (append $self-exact $self-by-symbol)))))
+
+(= (skill-card $skill)
+   (let* (($exact (collapse
+                    (match &skills (SkillCardLine $skill $line)
+                      (SkillCardLine $skill $line))))
+          ($symbol (repr $skill))
+          ($by-symbol (collapse
+                        (match &skills (SkillCardLine $symbol $line)
+                          (SkillCardLine $symbol $line))))
+          ($self-exact (collapse
+                         (match &self (SkillCardLine $skill $line)
+                           (SkillCardLine $skill $line))))
+          ($self-by-symbol (collapse
+                             (match &self (SkillCardLine $symbol $line)
+                               (SkillCardLine $symbol $line)))))
+         (list_to_set (append (append $exact $by-symbol)
+                              (append $self-exact $self-by-symbol)))))
