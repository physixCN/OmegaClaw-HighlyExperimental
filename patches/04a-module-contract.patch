+; Organ-local affordance declarations live beside their catalog/signature
+; declarations. They are plain atoms in &self, so optional organs only expose
+; affordance cards when their organ is imported.
+!(import! &self (library OmegaClaw-Core ./src/skill_affordance_core.metta))
+!(import! &self (library OmegaClaw-Core ./src/skill_affordance_energy.metta))
+!(import! &self (library OmegaClaw-Core ./src/skill_affordance_reasoning.metta))
+
+; ---------------------------------------------------------------------------
+; Situation features. These are examples the agent can extend later.
+; ---------------------------------------------------------------------------
+
+!(add-atom &skills (SituationFeature "reply-to-latest-whatsapp" "open-inbound-chat"))
+!(add-atom &skills (SituationFeature "inspect-whatsapp-before-reply" "unknown-chat-context"))
+!(add-atom &skills (SituationFeature "send-new-whatsapp-to-specific-chat" "deliberate-new-specific-chat"))
+!(add-atom &skills (SituationFeature "leave-chat-for-later" "reminder-needed"))
