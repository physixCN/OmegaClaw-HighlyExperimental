+            calls.append((method, path, payload))
+            if path == "/send-file":
+                return {"ok": True, "handled": {"changed": 0}}
+            if path == "/chat-state":
+                return {
+                    "ok": True,
+                    "jid": payload["jid"],
+                    "changed": 1,
+                    "readReceipts": {"attempted": 1, "sent": 1},
